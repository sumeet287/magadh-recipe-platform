DATABASE_URL="postgresql://postgres:password@localhost:5432/magadh_recipe_db"

# NextAuth (production: set to https://yourdomain.com — used for metadataBase, sitemap, OG URLs)
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Search Console HTML tag verification (optional; content value only, not full tag)
GOOGLE_SITE_VERIFICATION=""

# ---------- Web analytics (GA4 / GTM — Next.js sends virtual_page_view on client navigations) ----------
# Prefer one: NEXT_PUBLIC_GTM_ID (configure GA4 in GTM) OR NEXT_PUBLIC_GA_MEASUREMENT_ID (direct GA).
#NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
#NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# Comma-separated path prefixes skipped for SPA events (default when unset = /admin only).
#NEXT_PUBLIC_ANALYTICS_ROUTE_IGNORE_PREFIXES="/admin"
# GTM trigger: Custom Event "virtual_page_view" → GA4 page_view mapping Data Layer vars page_location / page_title / page_path.

# Optional: override empty product grid animation (.lottie URL or Lottie JSON URL; CORS must allow your site).
# Default file: public/lottie/product_not_found.lottie (and optional JSON fallback: public/lottie/no-item-found.json).
# NEXT_PUBLIC_PRODUCTS_EMPTY_LOTTIE_URL=""

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Razorpay (https://dashboard.razorpay.com)
# For production: use rzp_live_* keys from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxxxxx"

# Email (SMTP — can use Resend: smtp.resend.com:465)
# Port 465 = SSL (secure: true), Port 587 = STARTTLS (secure: false)
SMTP_HOST="smtp.resend.com"
SMTP_PORT="465"
SMTP_USER="resend"
SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@magadhrecipe.com"
FROM_NAME="Magadh Recipe"

# Resend (alternative to SMTP — https://resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Admin Notifications
# Email where new order notifications are sent (owner's email)
ADMIN_NOTIFICATION_EMAIL="magadhrecipe@gmail.com"

# ==================== WhatsApp (two-number architecture) ====================
#
# We use TWO different WhatsApp numbers:
#
#   A) ADMIN/OWNER number  (e.g. 916207197364)
#      - Used for the public "Order on WhatsApp" click-to-chat link on the site.
#      - Used as the destination for new-order notifications to the owner.
#      - Stays on the regular WhatsApp app (owner can reply to customers normally).
#
#   B) MARKETING / BOT number  (the NEW number registered with Meta Cloud API)
#      - Sends automated messages: abandoned checkout coupons, bulk broadcasts,
#        order confirmations to customers.
#      - CANNOT be used on the regular WhatsApp app once registered with Meta.
#      - All outbound templated messages leave from this number.
#
# ---- A) Admin / click-to-chat number ----
# Public-facing number (E.164 without +). Used by the floating "Order on WhatsApp"
# button and the header marquee.
NEXT_PUBLIC_WHATSAPP_NUMBER="916207197364"
# Where new-order WhatsApp alerts are sent. Usually same as NEXT_PUBLIC_WHATSAPP_NUMBER.
WHATSAPP_ADMIN_PHONE="916207197364"
WHATSAPP_ACCESS_TOKEN="your-meta-access-token"

# ---- B) Marketing / bot number (Meta Cloud API) ----
# Add & verify the new business number in Meta Business Manager, then grab:
#   - Phone number ID (numeric, shown under WhatsApp → API Setup)
#   - A permanent system-user access token scoped to this WABA
# Templates are scoped to this number — they must be approved in Meta before use.
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
# Template names (all must be approved on Meta before going live).
WHATSAPP_TEMPLATE_ORDER_NOTIFICATION="order_notifications"
# abandoned_checkout_coupon (Marketing): {{1}} customer name; brand name fixed in Meta body.
# {{2}} coupon, {{3}} expiry, {{4}} recovery URL — see sendAbandonedCheckoutCoupon.
WHATSAPP_TEMPLATE_ABANDONED_CHECKOUT="abandoned_checkout_coupon"
# Used by the admin "Quick Send" broadcast flow. Expected body shape:
#   Hi {{1}}! 🌿
#   {{2}}
#   Shop now at {{3}}
# {{1}} = recipient's first name (auto-filled per user), {{2}} = message body
# from admin, {{3}} = destination URL from admin.
WHATSAPP_TEMPLATE_MARKETING_BROADCAST="marketing_broadcast"
WHATSAPP_TEMPLATE_LANGUAGE="en"
# Arbitrary secret used during the Meta webhook handshake — must match the
# "Verify Token" entered in Meta dev console when subscribing to webhooks.
# If unset, a default constant is used (fine for dev).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# Kill-switch for outgoing WhatsApp template sends (abandoned checkout cron +
# admin broadcast cron). Defaults to PAUSED — while your marketing templates
# are still under Meta review, keep this unset/false so we don't send rejected
# templates and burn deliverability. Flip to "true" AFTER all three templates
# are approved (order_notifications, abandoned_checkout_coupon, marketing_broadcast).
WHATSAPP_TEMPLATES_READY="false"

# ==================== Amazon Selling Partner API (analytics tab — real orders) ====================
#
# Populate /admin/analytics?channel=amazon from live Amazon orders. After authorizing your
# SP-API app with the seller account, store LWA (Login with Amazon) credentials + refresh token.
#
# LWA_CLIENT_ID / LWA_CLIENT_SECRET: Developer Central → your SP-API app → LWA credentials
# LWA_REFRESH_TOKEN: OAuth / "Authorize" flow for the seller (long-lived refresh token)
# AMAZON_MARKETPLACE_ID: defaults to Amazon.in → A21TJRUUN4KGV if unset
# AMAZON_SP_API_REGION: Selling Partner endpoint region → na | eu | fe (India sellers typically use "eu")
#
# Cron: GET /api/cron/amazon-orders-sync (Vercel: see vercel.json; Hobby plan = once/day max)
# Manual (logged-in admin): POST /api/admin/amazon/sync-orders
#
#LWA_CLIENT_ID=""
#LWA_CLIENT_SECRET=""
#LWA_REFRESH_TOKEN=""
#AMAZON_MARKETPLACE_ID="A21TJRUUN4KGV"
#AMAZON_SP_API_REGION="eu"
# Hint for Seller Central deep links on analytics: "IN" (.in) vs US ("com"|"na"|"us"|"default")
#AMAZON_SELLER_CENTRAL_REGION=""
# Sandbox test orders (usually leave false in production):
#AMAZON_SP_API_SANDBOX="false"
# Incremental sync (“Pull latest”) — only orders **last updated** in this window:
#AMAZON_ORDERS_SYNC_LOOKBACK_DAYS="21"
# getOrders NextToken pages (100/order page). "0" ⇒ follow all pages (watch timeout on huge catalogs).
# Incremental pulls only (cron + “Pull latest”):
#AMAZON_ORDERS_SYNC_MAX_LIST_PAGES="8"

# Historical: defaults to exhaustive pagination per Created window — set only if you need a safety cap per chunk:
#AMAZON_ORDERS_HISTORICAL_MAX_LIST_PAGES="40"
# getOrderItems calls per incremental run (newest LastUpdateDate first):
#AMAZON_ORDERS_SYNC_MAX_ORDER_ITEM_FETCHES="40"

# Historical (“Import full history” in admin) — **Created** dates, up to Orders API age (~2 years for most marketplaces)
#AMAZON_ORDERS_HISTORICAL_CREATED_DAYS="720"
# Split into N-day windows (90 default). "0" ⇒ one Created window for the whole span (may fail if Amazon rejects it).
#AMAZON_ORDERS_HISTORICAL_CHUNK_DAYS="90"
# Line items inline during historical: unset ⇒ 0 (headers only — then use Fetch SKU lines). Set e.g. 50 to hydrate some SKUs inline.
#AMAZON_ORDERS_HISTORICAL_MAX_ORDER_ITEM_FETCHES="0"

# “Fetch SKU lines” batch — orders missing lines per POST:
#AMAZON_ORDERS_SYNC_MISSING_LINES_BATCH="40"

# Cloudinary (for image uploads — https://cloudinary.com)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Shiprocket (API integration — https://app.shiprocket.in)
SHIPROCKET_EMAIL="your-shiprocket-api-email"
SHIPROCKET_PASSWORD="your-shiprocket-api-password"
SHIPROCKET_PICKUP_PINCODE="800014"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Magadh Recipe"

# Google Search Console (optional)
GOOGLE_SITE_VERIFICATION=""

# Cron Secret (for scheduled tasks like abandoned order cleanup)
# Generate: openssl rand -base64 32
CRON_SECRET=""

# ==================== AI CONTENT ENGINE ====================
# Provider: "gemini" (default, FREE) or "openai" (paid).
# Gemini free tier allows 1,500 requests/day — far more than we need (3/week).
CONTENT_ENGINE_PROVIDER="gemini"

# ---- Gemini (FREE — recommended) ----
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional model override. Defaults to gemini-2.5-flash (free tier, current flagship fast model).
# Options: gemini-2.5-flash (default), gemini-2.5-flash-lite, gemini-1.5-flash.
# Note: gemini-2.0-flash has limit:0 for new projects as of April 2026 — avoid.
GEMINI_MODEL="gemini-2.5-flash"

# ---- OpenAI (paid, optional fallback) ----
# Only needed if CONTENT_ENGINE_PROVIDER="openai".
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o"

# If "false", AI-generated posts land as DRAFT for review instead of auto-publishing.
# Default "true" = auto-publish immediately. Schedule in vercel.json: Mon/Wed/Fri 9:00 IST.
BLOG_AUTO_PUBLISH="true"

# Optional: default cover image URL used when the AI doesn't supply one.
# CONTENT_ENGINE_DEFAULT_COVER=""

# ---- Free stock photo APIs (copyright-safe, commercial use allowed) ----
# Recommended: Pexels — free, instant, 200 req/hr. https://www.pexels.com/api/
PEXELS_API_KEY=""
# Optional fallback: Unsplash — free, 50 req/hr demo. https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=""
NEXT_PUBLIC_GTM_ID=GTM-PQ3FLR3K